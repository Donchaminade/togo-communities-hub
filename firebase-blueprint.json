{
  "entities": {
    "Community": {
      "title": "Community",
      "description": "A technology community in Lomé, Togo",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique community ID" },
        "name": { "type": "string", "description": "Name of the community" },
        "description": { "type": "string", "description": "Detailed description of the activities and mission" },
        "logoUrl": { "type": "string", "description": "Optional custom logo URL" },
        "tags": { "type": "array", "description": "List of technology domains (maximum 5)" },
        "whatsappUrl": { "type": "string", "description": "WhatsApp group invitation link" },
        "telegramUrl": { "type": "string", "description": "Telegram group invitation link" },
        "linkedinUrl": { "type": "string", "description": "LinkedIn profile page URL" },
        "twitterUrl": { "type": "string", "description": "Twitter/X profile URL" },
        "websiteUrl": { "type": "string", "description": "Official website URL" },
        "neighborhood": { "type": "string", "description": "Lomé neighbourhood where gatherings usually occur" },
        "lat": { "type": "number", "description": "Approximate latitude in Lomé" },
        "lng": { "type": "number", "description": "Approximate longitude in Lomé" },
        "leaderName": { "type": "string", "description": "Full name of the submission lead/owner" },
        "leaderEmail": { "type": "string", "description": "Email address of the community lead" },
        "leaderPhone": { "type": "string", "description": "WhatsApp or mobile contact telephone number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Moderation status of the community" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time the registration was requested" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Time of review or edition" }
      },
      "required": ["name", "description", "tags", "leaderName", "leaderEmail", "status"]
    }
  },
  "firestore": {
    "communities": {
      "schema": "Community",
      "description": "Collection of Lomé tech communities submitted by leaders"
    }
  }
}
